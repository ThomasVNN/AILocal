# OpenClaw note:
# - Non-loopback Control UI requires explicit HTTPS origin allowlist.
# - Reverse proxy trust is set to the current Traefik edge IP/32 by bootstrap_openclaw.sh.
# - Leave OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=false unless this is a tightly-controlled local/dev gateway.
# - Run once before starting `openclaw-gateway`:
#     bash deploy/scripts/bootstrap_openclaw.sh
OPENCLAW_BUILD_VARIANT=slim
OPENCLAW_BUILD_APT_UPGRADE=0
