##############################################################
# NeuroStack — Local Brand (M1 Mac, Apple Silicon arm64)
# Brand isolation: neurostack_* networks | *.nstack.local domains
# Ports: 81(HTTP) 9443(HTTPS) 8089(Traefik Dashboard)
# Data: .nstack-data/ (tách biệt hoàn toàn với .localagent-data/)
##############################################################

# =========================
# Shared
# =========================
TZ=Asia/Ho_Chi_Minh
# Absolute path recommended (used by Docker volume mounts).
# When using ops/nstack_deploy_local.sh, this will be auto-set to: <repo>/.nstack-data
NS_DATA_ROOT=/absolute/path/to/.nstack-data

# =========================
# Layer 1: Infra Platform
# =========================
POSTGRES_DB=neurostack
POSTGRES_USER=neurostack
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_24
POSTGRES_BACKUP_SCHEDULE=0 */6 * * *
POSTGRES_BACKUP_KEEP_DAYS=7
POSTGRES_BACKUP_KEEP_WEEKS=4
POSTGRES_BACKUP_KEEP_MONTHS=6

REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_24

MINIO_ROOT_USER=neurostack
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
MINIO_BOOTSTRAP_BUCKET=nstack-webui
MINIO_API_HOST=s3.nstack.local
MINIO_CONSOLE_HOST=minio.nstack.local

# Ports khác với localagent (80→81, 8443→9443, 8088→8089)
TRAEFIK_HTTP_PORT=81
TRAEFIK_HTTPS_PORT=9443
TRAEFIK_DASHBOARD_PORT=8089
TRAEFIK_DASHBOARD_HOST=traefik.nstack.local
TRAEFIK_TLS_ENABLED=true
TRAEFIK_HSTS_SECONDS=0
TRAEFIK_EDGE_IP=172.24.0.2

# =========================
# Layer 2: Compute Apps
# =========================

# OmniRouter (Central LLM Gateway — custom fork)
NS_OMNIROUTER_IMAGE=omnirouter:local
NS_OMNIROUTER_PLATFORM=linux/arm64
OMNIROUTER_PORT=21128
OMNIROUTER_DASHBOARD_PORT=21128
OMNIROUTER_API_PORT=21129
OMNIROUTER_HOST=router.nstack.local
OMNIROUTER_API_HOST=api.nstack.local
OMNIROUTER_PUBLIC_URL=https://router.nstack.local:9443

# OmniRouter secrets (required)
# Generate:
#   openssl rand -base64 48   # JWT_SECRET
#   openssl rand -hex 32      # API_KEY_SECRET / STORAGE_ENCRYPTION_KEY
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
API_KEY_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
INITIAL_PASSWORD=NeuroStack@local
STORAGE_DRIVER=sqlite
STORAGE_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
STORAGE_ENCRYPTION_KEY_VERSION=v1
MACHINE_ID_SALT=CHANGE_ME_generate_with_openssl_rand_hex_16
REQUIRE_API_KEY=false
AUTH_COOKIE_SECURE=true

# OpenWebUI (Chat UI — custom fork)
OPENWEBUI_TAG=main
OPENWEBUI_HOST=chat.nstack.local
# API key được provision bởi bootstrap_app_clients.sh — không điền thủ công
OPENWEBUI_OPENAI_API_KEY=
# NOTE: giữ password aligned với POSTGRES_PASSWORD (URL-encode nếu cần)
OPENWEBUI_DATABASE_URL=postgresql://neurostack:CHANGE_ME_generate_with_openssl_rand_hex_24@postgres-primary:5432/neurostack
OPENWEBUI_DATABASE_SCHEMA=public
# NOTE: giữ password aligned với REDIS_PASSWORD
OPENWEBUI_REDIS_URL=redis://:CHANGE_ME_generate_with_openssl_rand_hex_24@redis:6379/0
OPENWEBUI_WEBSOCKET_REDIS_URL=redis://:CHANGE_ME_generate_with_openssl_rand_hex_24@redis:6379/0
OPENWEBUI_REDIS_KEY_PREFIX=ns-open-webui
OPENWEBUI_S3_ENDPOINT_URL=http://minio:9000
OPENWEBUI_S3_ACCESS_KEY_ID=neurostack
# NOTE: giữ secret aligned với MINIO_ROOT_PASSWORD
OPENWEBUI_S3_SECRET_ACCESS_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
OPENWEBUI_S3_BUCKET_NAME=nstack-webui
OPENWEBUI_S3_REGION_NAME=us-east-1
OPENWEBUI_S3_ADDRESSING_STYLE=path

# OpenClaw (Automation Gateway — custom fork)
NS_OPENCLAW_IMAGE=openclaw:local
NS_OPENCLAW_PLATFORM=linux/arm64
OPENCLAW_HOST=claw.nstack.local
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
# API key được provision bởi bootstrap_app_clients.sh
OPENCLAW_OPENAI_API_KEY=
OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=true

# Per-user OpenClaw isolation:
# - Mỗi user có OPENCLAW_USER_TOKEN riêng (provisioned qua bootstrap_app_clients.sh)
# - Mỗi user có OmniRouter API key riêng (quota tracking per user)
# - Workspace data isolated: ${NS_DATA_ROOT}/apps/openclaw/workspace/{userId}/

# OpenClaw note:
# - Non-loopback Control UI requires explicit HTTPS origin allowlist.
# - Run once before starting openclaw-gateway:
#     ENV_FILE=deploy/env/nstack.local.env bash deploy/scripts/bootstrap_openclaw.sh
# Flag để script nhận biết đây là file được generate
NS_ENV_GENERATED=0
