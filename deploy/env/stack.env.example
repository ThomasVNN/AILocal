# =========================
# Shared
# =========================
TZ=Asia/Ho_Chi_Minh
LA_DATA_ROOT=/data/localagent
LOCALAGENT_USE_REGISTRY_IMAGES=false
LOCALAGENT_IMAGE_REGISTRY=mizuk1210.mulley-ray.ts.net:9999
LOCALAGENT_PLATFORM_NAMESPACE=localagent-platform
LOCALAGENT_APPS_NAMESPACE=localagent-apps
LOCALAGENT_IMAGE_TAG=dev
APP_PULL_POLICY=never

# =========================
# Layer 1: Infra Platform
# =========================
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_BACKUP_IMAGE=prodrigestivill/postgres-backup-local:16
POSTGRES_DB=openwebui
POSTGRES_USER=localagent
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_BACKUP_SCHEDULE=0 */6 * * *
POSTGRES_BACKUP_KEEP_DAYS=7
POSTGRES_BACKUP_KEEP_WEEKS=4
POSTGRES_BACKUP_KEEP_MONTHS=6

REDIS_PASSWORD=change-this-redis-password
REDIS_IMAGE=redis:7-alpine

MINIO_ROOT_USER=localagent
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
MINIO_BOOTSTRAP_BUCKET=openwebui
MINIO_API_HOST=s3.localagent.local
MINIO_CONSOLE_HOST=minio.localagent.local

TRAEFIK_IMAGE=traefik:v3.1
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8088
TRAEFIK_DASHBOARD_HOST=traefik.localagent.local
TRAEFIK_TLS_ENABLED=true
TRAEFIK_HSTS_SECONDS=0
TRAEFIK_EDGE_IP=172.23.0.2

# =========================
# Layer 2: Compute Apps
# =========================
OMNIROUTE_IMAGE=omniroute:intel
OMNIROUTE_PLATFORM=linux/amd64
OMNIROUTE_PORT=20128
OMNIROUTE_DASHBOARD_PORT=20128
OMNIROUTE_API_PORT=20129
OMNIROUTE_HOST=router.localagent.local
OMNIROUTE_API_HOST=api.localagent.local
OMNIROUTE_PUBLIC_URL=https://router.localagent.local

# OmniRoute secrets (required)
# Generate with:
#   openssl rand -base64 48   # JWT_SECRET
#   openssl rand -hex 32      # API_KEY_SECRET / STORAGE_ENCRYPTION_KEY
JWT_SECRET=change-this-jwt-secret
API_KEY_SECRET=change-this-api-key-secret
INITIAL_PASSWORD=uat-d18fee1168fbeaab012467c7
STORAGE_DRIVER=sqlite
STORAGE_ENCRYPTION_KEY=change-this-storage-encryption-key
STORAGE_ENCRYPTION_KEY_VERSION=v1
MACHINE_ID_SALT=change-this-machine-id-salt
REQUIRE_API_KEY=false
AUTH_COOKIE_SECURE=true
ENABLE_TLS_FINGERPRINT=true

OPENWEBUI_IMAGE=open-webui:intel
OPENWEBUI_PLATFORM=linux/amd64
OPENWEBUI_HOST=chat.localagent.local
# OmniRoute API key (create in OmniRoute dashboard) OR set REQUIRE_API_KEY=false during bootstrap
OPENWEBUI_OPENAI_API_KEY=change-this-app-key
# NOTE: keep password in this URL aligned with POSTGRES_PASSWORD above (URL-encode if needed)
OPENWEBUI_DATABASE_URL=postgresql://localagent:change-this-postgres-password@postgres-primary:5432/openwebui
OPENWEBUI_DATABASE_SCHEMA=public
# NOTE: keep password in this URL aligned with REDIS_PASSWORD above (URL-encode if needed)
OPENWEBUI_REDIS_URL=redis://:change-this-redis-password@redis:6379/0
OPENWEBUI_WEBSOCKET_REDIS_URL=redis://:change-this-redis-password@redis:6379/0
OPENWEBUI_REDIS_KEY_PREFIX=open-webui
OPENWEBUI_S3_ENDPOINT_URL=http://minio:9000
OPENWEBUI_S3_ACCESS_KEY_ID=localagent
# NOTE: keep secret aligned with MINIO_ROOT_PASSWORD above
OPENWEBUI_S3_SECRET_ACCESS_KEY=change-this-minio-password
OPENWEBUI_S3_BUCKET_NAME=openwebui
OPENWEBUI_S3_REGION_NAME=us-east-1
OPENWEBUI_S3_ADDRESSING_STYLE=path
OPENWEBUI_BUILD_USE_SLIM=true
OPENWEBUI_BUILD_USE_OLLAMA=false
OPENWEBUI_BUILD_USE_PERMISSION_HARDENING=false
OPENWEBUI_BUILD_HASH=localagent-source

OPENCLAW_IMAGE=openclaw:intel
OPENCLAW_PLATFORM=linux/amd64
OPENCLAW_HOST=openclaw.localagent.local
OPENCLAW_GATEWAY_TOKEN=change-this-openclaw-token
# OmniRoute API key (create in OmniRoute dashboard) OR set REQUIRE_API_KEY=false during bootstrap
OPENCLAW_OPENAI_API_KEY=change-this-app-key
OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=false

# OpenClaw note:
# - Non-loopback Control UI requires explicit HTTPS origin allowlist.
# - Reverse proxy trust is set to the current Traefik edge IP/32 by bootstrap_openclaw.sh.
# - Set OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=true only for trusted local/dev deployments.
# - Run once before starting `openclaw-gateway`:
#     bash deploy/scripts/bootstrap_openclaw.sh
