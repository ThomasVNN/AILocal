##############################################################
# NeuroStack — Server Brand (Linux Intel x86_64, amd64)
# Server: 192.168.1.65 / Tailscale: 100.101.77.8
# User: mzk-12-10
# Deploy path: /home/mzk-12-10/neurostack/
# Data root: /data/neurostack/ (tách biệt với /data/localagent/)
##############################################################
# CẢNH BÁO: Ports dùng trên server (không đụng localagent stack):
#   Port 80   → đã dùng bởi localagent-traefik
#   Port 8080 → đã dùng bởi cadvisor
#   Port 9443 → đã dùng bởi portainer
#   Port 9000 → đã dùng bởi portainer
#   NeuroStack dùng: 8181(HTTP), 8444(HTTPS), 8090(Traefik Dashboard)
##############################################################

# =========================
# Shared
# =========================
TZ=Asia/Ho_Chi_Minh
NS_DATA_ROOT=/data/neurostack

# =========================
# Resource Profile (Linux Intel 8GB RAM — tight limits for UAT)
# Total allocated: ~3.7GB → leaves ~4.3GB for OS + Docker overhead
# =========================
NS_PG_MEM_LIMIT=384M
NS_PG_CPU_LIMIT=1.0
NS_PG_SHARED_BUFFERS=128MB
NS_PG_WORK_MEM=2MB
NS_PG_EFFECTIVE_CACHE=256MB
NS_PG_MAX_CONNECTIONS=30
NS_PG_SLOW_QUERY_MS=500
NS_PG_BACKUP_MEM_LIMIT=128M
NS_REDIS_MEM_LIMIT=200M
NS_MINIO_MEM_LIMIT=256M
NS_TRAEFIK_MEM_LIMIT=128M
NS_OMNIROUTER_MEM_LIMIT=768M
NS_OMNIROUTER_CPU_LIMIT=1.5
NS_OPENWEBUI_MEM_LIMIT=768M
NS_OPENWEBUI_CPU_LIMIT=1.5
NS_OPENCLAW_MEM_LIMIT=512M
NS_OPENCLAW_CPU_LIMIT=1.0
NS_OPENCLAW_CLI_MEM_LIMIT=192M

# =========================
# Layer 1: Infra Platform
# =========================
POSTGRES_DB=neurostack
POSTGRES_USER=neurostack
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_24
POSTGRES_BACKUP_SCHEDULE=0 */6 * * *
POSTGRES_BACKUP_KEEP_DAYS=7
POSTGRES_BACKUP_KEEP_WEEKS=4
POSTGRES_BACKUP_KEEP_MONTHS=6

REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_24

MINIO_ROOT_USER=neurostack
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
MINIO_BOOTSTRAP_BUCKET=nstack-webui
MINIO_API_HOST=s3.nstack.server
MINIO_CONSOLE_HOST=minio.nstack.server

# Server ports (tránh xung đột với localagent + các services khác)
TRAEFIK_HTTP_PORT=8181
TRAEFIK_HTTPS_PORT=8444
TRAEFIK_DASHBOARD_PORT=8090
TRAEFIK_DASHBOARD_HOST=traefik.nstack.server
TRAEFIK_TLS_ENABLED=true
TRAEFIK_HSTS_SECONDS=0

# =========================
# Layer 2: Compute Apps
# =========================

# OmniRouter (Central LLM Gateway — custom fork, built for linux/amd64)
NS_OMNIROUTER_IMAGE=omnirouter:intel
NS_OMNIROUTER_PLATFORM=linux/amd64
OMNIROUTER_PORT=21128
OMNIROUTER_DASHBOARD_PORT=21128
OMNIROUTER_API_PORT=21129
OMNIROUTER_HOST=router.nstack.server
OMNIROUTER_API_HOST=api.nstack.server
OMNIROUTER_PUBLIC_URL=https://router.nstack.server:8444

JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
API_KEY_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
INITIAL_PASSWORD=CHANGE_ME_strong_password
STORAGE_DRIVER=sqlite
STORAGE_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
STORAGE_ENCRYPTION_KEY_VERSION=v1
MACHINE_ID_SALT=CHANGE_ME_generate_with_openssl_rand_hex_16
REQUIRE_API_KEY=false
AUTH_COOKIE_SECURE=true
ENABLE_TLS_FINGERPRINT=true

# OpenWebUI (Chat UI — custom fork)
OPENWEBUI_TAG=main
OPENWEBUI_HOST=chat.nstack.server
OPENWEBUI_OPENAI_API_KEY=
OPENWEBUI_DATABASE_URL=postgresql://neurostack:CHANGE_ME_generate_with_openssl_rand_hex_24@postgres-primary:5432/neurostack
OPENWEBUI_DATABASE_SCHEMA=public
OPENWEBUI_REDIS_URL=redis://:CHANGE_ME_generate_with_openssl_rand_hex_24@redis:6379/0
OPENWEBUI_WEBSOCKET_REDIS_URL=redis://:CHANGE_ME_generate_with_openssl_rand_hex_24@redis:6379/0
OPENWEBUI_REDIS_KEY_PREFIX=ns-open-webui
OPENWEBUI_S3_ENDPOINT_URL=http://minio:9000
OPENWEBUI_S3_ACCESS_KEY_ID=neurostack
OPENWEBUI_S3_SECRET_ACCESS_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
OPENWEBUI_S3_BUCKET_NAME=nstack-webui
OPENWEBUI_S3_REGION_NAME=us-east-1
OPENWEBUI_S3_ADDRESSING_STYLE=path

# OpenClaw (Automation Gateway — custom fork, built for linux/amd64)
NS_OPENCLAW_IMAGE=openclaw:intel
NS_OPENCLAW_PLATFORM=linux/amd64
OPENCLAW_HOST=claw.nstack.server
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_generate_with_openssl_rand_hex_32
OPENCLAW_OPENAI_API_KEY=
OPENCLAW_CONTROL_UI_DISABLE_DEVICE_AUTH=false

NS_ENV_GENERATED=0
